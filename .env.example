# Copy this file to reynolds_family_dashboard/.env and fill in your values.

# Supabase — the database that stores events, tasks, groceries, etc.
# Find both in your Supabase project: Settings > API.
SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Gemini — powers the AI assistant bar at the bottom of the app.
# Get a key from Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
